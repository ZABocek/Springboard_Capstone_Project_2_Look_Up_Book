# ============================================
# SECURITY-CRITICAL FILES
# ============================================
# Environment variables
.env
.env.local
.env.*.local
.env.production.local

# Private keys and certificates
*.pem
*.key
*.crt

# ============================================
# DEPENDENCIES & LOCK FILES
# ============================================
# Node modules
node_modules/
/.pnp
.pnp.js

# Package manager lock files can be committed but node_modules cannot
# Uncomment below to also ignore lock files:
# package-lock.json
# yarn.lock

# ============================================
# LOGS
# ============================================
logs/
logs.txt
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pip-log.txt
pip-delete-this-directory.txt

# ============================================
# TESTING
# ============================================
/coverage
.nyc_output/
.pytest_cache/
__pycache__/
*.egg-info/
dist/
build/

# ============================================
# IDE & EDITOR FILES
# ============================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ============================================
# OS FILES
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
desktop.ini
Thumbs.db
ehthumbs.db

# ============================================
# BUILD & OUTPUT DIRECTORIES
# ============================================
build/
dist/
out/
.next/
.nuxt/

# ============================================
# TEMPORARY & CACHE FILES
# ============================================
*.tmp
*.temp
.cache/
.parcel-cache/
.eslintcache
.pytest_cache/
.turbo/
.vercel

# ============================================
# DATABASE FILES
# ============================================
# Exclude SQL dumps except for templates/seeds
*.sql
!consolidated_database.sql
!current-database-7.sql
*.sqlite
*.db
*.postgres

# ============================================
# PRIVATE & SENSITIVE
# ============================================
secrets/
.private/
.secrets/
credentials.json
service-account.json

# ============================================
# MISC
# ============================================
.cache/
.parcel-cache/
