{
    "name": "server",
    "version": "1.0.0",
    "description": "Backend server for the React application",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "test": "jest --runInBand --forceExit"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": ["**/__tests__/**/*.test.js", "**/*.test.js"],
        "testPathIgnorePatterns": ["/node_modules/"]
