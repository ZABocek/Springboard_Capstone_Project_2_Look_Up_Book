        "body-parser": "^1.19.0",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^8.2.0",
        "express": "^4.21.2",
        "ioredis": "^5.10.1",
        "jsonwebtoken": "^9.0.2",
        "pg": "^8.11.3",
        "uuidv4": "^6.2.13"
    },
    "devDependencies": {
        "jest": "^30.3.0",
        "supertest": "^7.2.2"
    }
}
